# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SPOTIFY_CLIENT_ID: Optional. Your Spotify Developer application Client ID.
# Register an app at https://developer.spotify.com/dashboard/
# Add "${APP_URL}/api/spotify/callback" to your Redirect URIs in the Spotify dashboard.
SPOTIFY_CLIENT_ID=""

# SPOTIFY_CLIENT_SECRET: Optional. Your Spotify Developer application Client Secret.
SPOTIFY_CLIENT_SECRET=""

# GEMINI_API_KEY: Optional if Spotify Ranking Only is checked. Required for AI playlist curation.
# Get an API key from Google AI Studio.
GEMINI_API_KEY=""

# Vercel / Client Fallback environment variables (Optional fallback)
VITE_SPOTIFY_CLIENT_ID=""
VITE_GEMINI_API_KEY=""
